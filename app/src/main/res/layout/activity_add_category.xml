<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Category"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            android:padding="16dp"
            android:background="@drawable/header_background" />

        <!-- Parent Category Selection Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Parent Category"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvSelectedParent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Root Level (Main Category)"
                    android:textSize="14sp"
                    android:textColor="#666"
                    android:layout_marginBottom="12dp"
                    android:padding="12dp"
                    android:background="@drawable/spinner_background" />

                <!-- Level Indicator -->
                <TextView
                    android:id="@+id/tvLevelInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Level: 1 (Root)"
                    android:textSize="12sp"
                    android:textColor="#2196F3"
                    android:layout_marginBottom="12dp"
                    android:textStyle="italic" />

                <Button
                    android:id="@+id/btnSelectParent"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Select Parent Category"
                    android:textSize="16sp"
                    android:backgroundTint="#2196F3"
                    android:textColor="@android:color/white" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- New Category Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="New Category Details"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="16dp" />

                <!-- Category Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="#1a237e"
                    app:hintTextColor="#666">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCategoryName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Category Name"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Category ID -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="#1a237e"
                    app:hintTextColor="#666">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCategoryId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Category ID (auto-generated if empty)"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Initial Expansion State -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Initial State"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupExpansion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/radioExpanded"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Expanded"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioCollapsed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Collapsed" />

                </RadioGroup>

                <!-- Add Sample Items -->
                <CheckBox
                    android:id="@+id/cbAddSampleItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add sample items with current date"
                    android:textSize="14sp"
                    android:layout_marginBottom="16px" />

                <!-- Level Warning -->
                <TextView
                    android:id="@+id/tvLevelWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Maximum level depth: 4"
                    android:textSize="12sp"
                    android:textColor="#FF9800"
                    android:textStyle="italic"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Cancel"
                android:textSize="16sp"
                android:backgroundTint="#f44336"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnSaveCategory"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Save Category"
                android:textSize="16sp"
                android:backgroundTint="#4CAF50"
                android:textColor="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>